{
  "title": "ArgoCD / App Health & Sync",
  "uid": "argocd-app-health",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "browser",
  "tags": ["argocd", "gitops"],
  "templating": {
    "list": [
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(argocd_app_info, project)",
        "refresh": 2,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Apps",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "count(argocd_app_info{project=~\"$project\"})",
          "legendFormat": "apps",
          "refId": "A",
          "instant": true
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "orientation": "auto" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Healthy",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "count(argocd_app_info{project=~\"$project\", health_status=\"Healthy\"})",
          "legendFormat": "healthy",
          "refId": "A",
          "instant": true
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "orientation": "auto" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Degraded",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "count(argocd_app_info{project=~\"$project\", health_status=\"Degraded\"}) or vector(0)",
          "legendFormat": "degraded",
          "refId": "A",
          "instant": true
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "orientation": "auto" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Progressing",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "count(argocd_app_info{project=~\"$project\", health_status=\"Progressing\"}) or vector(0)",
          "legendFormat": "progressing",
          "refId": "A",
          "instant": true
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "orientation": "auto" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] } },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "OutOfSync",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "count(argocd_app_info{project=~\"$project\", sync_status=\"OutOfSync\"}) or vector(0)",
          "legendFormat": "out of sync",
          "refId": "A",
          "instant": true
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "orientation": "auto" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] } },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Sync Errors (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(argocd_app_sync_total{project=~\"$project\", phase=\"Error\"}[1h])) or vector(0)",
          "legendFormat": "sync errors",
          "refId": "A",
          "instant": true
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "orientation": "auto" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Application Status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "argocd_app_info{project=~\"$project\"}",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "options": { "sortBy": [{ "displayName": "name", "desc": false }] },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "health_status" }, "properties": [
            { "id": "custom.width", "value": 110 },
            { "id": "mappings", "value": [
              { "type": "value", "options": { "Healthy":     { "text": "● Healthy",     "color": "green"  } } },
              { "type": "value", "options": { "Degraded":    { "text": "● Degraded",    "color": "red"    } } },
              { "type": "value", "options": { "Progressing": { "text": "● Progressing", "color": "orange" } } },
              { "type": "value", "options": { "Unknown":     { "text": "● Unknown",     "color": "gray"   } } }
            ]}
          ]},
          { "matcher": { "id": "byName", "options": "sync_status" }, "properties": [
            { "id": "custom.width", "value": 110 },
            { "id": "mappings", "value": [
              { "type": "value", "options": { "Synced":    { "text": "✓ Synced",    "color": "green"  } } },
              { "type": "value", "options": { "OutOfSync": { "text": "✗ OutOfSync", "color": "orange" } } },
              { "type": "value", "options": { "Unknown":   { "text": "? Unknown",   "color": "gray"   } } }
            ]}
          ]},
          { "matcher": { "id": "byName", "options": "name" },      "properties": [{ "id": "custom.width", "value": 180 }] },
          { "matcher": { "id": "byName", "options": "namespace" },  "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "Time" },       "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "Value" },      "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "instance" },   "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "job" },        "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "pod" },        "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "container" },  "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "endpoint" },   "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "service" },    "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "exported_namespace" }, "properties": [{ "id": "custom.hidden", "value": true }] }
        ]
      },
      "transformations": [{ "id": "organize", "options": {} }]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Sync Operations — Succeeded vs Failed",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (phase) (rate(argocd_app_sync_total{project=~\"$project\"}[5m]))",
          "legendFormat": "{{phase}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Succeeded" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byRegexp", "options": "Error|Failed" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "App Reconcile Duration (p50 / p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(argocd_app_reconcile_bucket{project=~\"$project\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(argocd_app_reconcile_bucket{project=~\"$project\"}[5m])))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    }
  ]
}
