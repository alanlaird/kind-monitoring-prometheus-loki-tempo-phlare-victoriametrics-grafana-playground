{
  "title": "MetalLB / LoadBalancer Services",
  "uid": "metallb-services-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["metallb", "networking"],
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "LoadBalancer Services",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "count(kube_service_spec_type{type=\"LoadBalancer\"})",
          "legendFormat": "services",
          "refId": "A",
          "instant": true
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "orientation": "auto" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Services with Assigned IPs",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "count(kube_service_status_load_balancer_ingress)",
          "legendFormat": "assigned",
          "refId": "A",
          "instant": true
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "orientation": "auto" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "MetalLB Speaker Pods Ready",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_ready{namespace=\"metallb-system\", pod=~\"metallb-speaker.*\"})",
          "legendFormat": "speakers ready",
          "refId": "A",
          "instant": true
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "orientation": "auto" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Controller Ready",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_ready{namespace=\"metallb-system\", pod=~\"metallb-controller.*\"})",
          "legendFormat": "controller",
          "refId": "A",
          "instant": true
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "orientation": "auto" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "Down", "color": "red" }, "1": { "text": "Ready", "color": "green" } } }],
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "LoadBalancer Service Inventory",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "kube_service_status_load_balancer_ingress * on(namespace, service) group_left(type) kube_service_spec_type{type=\"LoadBalancer\"}",
          "legendFormat": "{{namespace}} / {{service}} → {{ip}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "options": { "sortBy": [{ "displayName": "namespace", "desc": false }] },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "namespace" }, "properties": [{ "id": "custom.width", "value": 160 }] },
          { "matcher": { "id": "byName", "options": "service" },   "properties": [{ "id": "custom.width", "value": 240 }] },
          { "matcher": { "id": "byName", "options": "ip" },        "properties": [{ "id": "custom.width", "value": 160 }] },
          { "matcher": { "id": "byName", "options": "Time" },      "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "Value" },     "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "type" },      "properties": [{ "id": "custom.hidden", "value": true }] }
        ]
      },
      "transformations": [{ "id": "organize", "options": {} }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "MetalLB Pod CPU",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"metallb-system\", container!=\"\"}[5m]))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "MetalLB Pod Memory",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"metallb-system\", container!=\"\"})",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    }
  ]
}
