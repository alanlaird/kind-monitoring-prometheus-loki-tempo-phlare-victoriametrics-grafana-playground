{
  "title": "Cert-Manager / Certificate Health",
  "uid": "cert-manager-health",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5m",
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "tags": ["cert-manager", "certificates"],
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "cert-manager Pods Ready",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_ready{namespace=\"cert-manager\"})",
          "legendFormat": "ready",
          "refId": "A",
          "instant": true
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "orientation": "auto" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 1 }, { "color": "green", "value": 3 }] } },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pod Restarts",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_restarts_total{namespace=\"cert-manager\"})",
          "legendFormat": "restarts",
          "refId": "A",
          "instant": true
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "orientation": "auto" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] } },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Certificate Read Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(certwatcher_read_certificate_total[5m]))",
          "legendFormat": "reads/s",
          "refId": "A",
          "instant": true
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "auto", "orientation": "auto" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Certificate Read Errors",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(certwatcher_read_certificate_errors_total[1h]))",
          "legendFormat": "errors (1h)",
          "refId": "A",
          "instant": true
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "orientation": "auto" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "API Server Client Certificate TTL",
      "description": "Time remaining on client certificates used by the API server",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.05, sum by (le) (rate(apiserver_client_certificate_expiration_seconds_bucket[5m])))",
          "legendFormat": "p5 (soonest expiry)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(apiserver_client_certificate_expiration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 604800 }, { "color": "green", "value": 2592000 }] },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Certificate Read Rate & Errors",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(certwatcher_read_certificate_total[5m]))",
          "legendFormat": "reads/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(certwatcher_read_certificate_errors_total[5m]))",
          "legendFormat": "errors/s",
          "refId": "B"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "errors/s" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "cert-manager CPU Usage",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"cert-manager\", container!=\"\"}[5m]))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "cert-manager Memory Usage",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"cert-manager\", container!=\"\"})",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    }
  ]
}
